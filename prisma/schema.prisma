datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}


model Question {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  difficulty       String   // Easy, Medium, Hard
  problemStatement String   // Markdown format text
  initialCode      String   // Starter template function
  constraints      String   // Markdown format constraints
}

model InterviewSession {
  id           String   @id @default(uuid())
  questionSlug String
  currentStep  Int      @default(1)
  history      String   // SQLite optimized JSON text string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}